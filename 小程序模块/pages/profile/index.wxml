<navigation-bar title="我的" back="{{false}}" color="#ffffff" background="transparent"></navigation-bar>
<view class="page">
  <view class="header">
    <view class="title">个人中心</view>
    <view class="desc">这里支持角色切换，后续会按不同身份展示不同内容。</view>
  </view>

  <view class="role-card">
    <view class="role-card__title">当前可用角色</view>
    <view class="role-list">
      <block wx:for="{{roles}}" wx:key="name">
        <view class="role-item {{item.active ? 'role-item--active' : ''}}" bindtap="onRoleTap" data-index="{{index}}">
          {{item.name}}
        </view>
      </block>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item">账号资料</view>
    <view class="menu-item">申请成为打手</view>
    <view class="menu-item">优惠券</view>
    <view class="menu-item">联系客服</view>
  </view>
</view>
