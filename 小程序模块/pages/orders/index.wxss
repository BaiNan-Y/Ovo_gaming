page {
  min-height: 100vh;
  background: #f4f6fb;
}

.page {
  padding: 24rpx;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.tabs {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-bottom: 22rpx;
}

.tab {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #475569;
  font-size: 24rpx;
}

.tab--active {
  background: #111827;
  color: #ffffff;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(17, 24, 39, 0.06);
}

.card__top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.card__status {
  font-size: 22rpx;
  color: #ff7a2f;
}

.card__meta {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6b7280;
}
