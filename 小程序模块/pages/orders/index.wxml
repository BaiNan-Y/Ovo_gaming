<navigation-bar title="订单页" back="{{false}}" color="#ffffff" background="transparent"></navigation-bar>
<view class="page">
  <view class="header">
    <view class="title">老板订单</view>
    <view class="desc">这里可以查看支付、派单、进行中和待审核的订单。</view>
  </view>

  <view class="tabs">
    <block wx:for="{{orderTabs}}" wx:key="index">
      <view class="tab {{activeTab === index ? 'tab--active' : ''}}" bindtap="switchTab" data-index="{{index}}">
        {{item}}
      </view>
    </block>
  </view>

  <view class="list">
    <block wx:for="{{orders}}" wx:key="title">
      <view class="card">
        <view class="card__top">
          <view class="card__title">{{item.title}}</view>
          <view class="card__status">{{item.status}}</view>
        </view>
        <view class="card__meta">{{item.time}} · {{item.amount}}</view>
      </view>
    </block>
  </view>
</view>
