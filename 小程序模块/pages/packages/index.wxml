<navigation-bar title="套餐页" back="{{false}}" color="#ffffff" background="transparent"></navigation-bar>
<view class="page">
  <view class="header">
    <view class="title">三角洲行动热门套餐</view>
    <view class="desc">价格已写在套餐里，下单时直接选择套餐和优惠即可。</view>
  </view>

  <view class="list">
    <block wx:for="{{packages}}" wx:key="title">
      <view class="card">
        <view class="card__top">
          <view class="card__title">{{item.title}}</view>
          <view class="card__price">{{item.price}}</view>
        </view>
        <view class="card__desc">{{item.desc}}</view>
      </view>
    </block>
  </view>

  <view class="bottom-action" bindtap="onOrderTap">去首页下单</view>
</view>
