page {
  min-height: 100vh;
  background: #f4f6fb;
}

.page {
  padding: 24rpx;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.role-card,
.menu {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(17, 24, 39, 0.06);
}

.role-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.role-list {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.role-item {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4338ca;
  font-size: 24rpx;
}

.role-item--active {
  background: linear-gradient(135deg, #ff8a3d, #ff6b2c);
  color: #ffffff;
}

.menu {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.menu-item {
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #111827;
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-item:last-child {
  border-bottom: none;
}
