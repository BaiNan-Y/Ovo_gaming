page {
  min-height: 100vh;
  background: #f4f6fb;
}

.page {
  padding: 24rpx;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(17, 24, 39, 0.06);
}

.card__top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.card__price {
  font-size: 32rpx;
  font-weight: 800;
  color: #ff7a2f;
}

.card__desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.bottom-action {
  margin-top: 28rpx;
  padding: 24rpx 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff8a3d, #ff6b2c);
  color: #fff;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}
